# Snowflake Demo Configuration
# Copy this file to .env and update with your values

# Connection name from `snow connection list`
SNOWFLAKE_CONNECTION_NAME=your_connection_name

# Compute resources
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_COMPUTE_POOL=CHURN_MODEL_POOL

# Database (usually no need to change)
SNOWFLAKE_DATABASE=CHURN_PREDICTION_DEMO
SNOWFLAKE_SCHEMA=ML
